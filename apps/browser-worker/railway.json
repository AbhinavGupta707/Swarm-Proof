{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.worker",
    "watchPatterns": [
      "/apps/browser-worker/**",
      "/packages/ai/**",
      "/packages/types/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @swarmproof/browser-worker start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
