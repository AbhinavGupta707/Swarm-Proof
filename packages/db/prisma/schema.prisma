generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Audit {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?
  targetUrl     String
  normalizedUrl String?
  goal          String
  status        AuditStatus @default(CREATED)
  provider      String      @default("memory-demo-adapter")
  modes         Json
  maxSteps      Int         @default(15)
  preflightJson Json?
  errorCode     String?
  errorMessage  String?
  shareToken    String?     @unique
  runs          AgentRun[]
  issues        Issue[]
  artifacts     Artifact[]
  jobs          AuditJob[]
  events        EventLog[]
  report        AuditReport?
}

enum AuditStatus {
  CREATED
  PREFLIGHT
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model AgentRun {
  id         String      @id @default(cuid())
  auditId    String
  audit      Audit       @relation(fields: [auditId], references: [id])
  persona    String
  mode       String      @default("normal")
  viewport   String
  status     RunStatus   @default(PENDING)
  startedAt  DateTime?
  finishedAt DateTime?
  success    Boolean?
  summary    String?
  steps      BrowserStep[]
  artifacts  Artifact[]
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  BLOCKED
  TIMED_OUT
}

model BrowserStep {
  id            String   @id @default(cuid())
  runId         String
  run           AgentRun @relation(fields: [runId], references: [id])
  stepIndex     Int
  action        String
  status        String?
  thought       String?
  selector      String?
  value         String?
  url           String?
  result        String
  screenshotUrl String?
  artifactId    String?
  createdAt     DateTime @default(now())
}

model Issue {
  id              String        @id @default(cuid())
  auditId          String
  audit            Audit         @relation(fields: [auditId], references: [id])
  severity         IssueSeverity
  category         String
  title            String
  description      String
  evidenceStepIds  Json
  suggestedFix     String?
  generatedTest    String?
  createdAt        DateTime      @default(now())
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Artifact {
  id          String       @id @default(cuid())
  auditId     String?
  audit       Audit?       @relation(fields: [auditId], references: [id])
  runId       String?
  run         AgentRun?    @relation(fields: [runId], references: [id])
  type        ArtifactType
  url         String
  storageKey  String?
  contentType String?
  sizeBytes   Int?
  meta        Json?
  createdAt   DateTime     @default(now())
}

enum ArtifactType {
  SCREENSHOT
  TRACE_ZIP
  HAR
  CONSOLE_LOG
  NETWORK_LOG
  VIDEO
}

model AuditJob {
  id        String         @id @default(cuid())
  auditId   String
  audit     Audit          @relation(fields: [auditId], references: [id])
  runId     String?
  status    AuditJobStatus @default(QUEUED)
  provider  String
  attempts  Int            @default(0)
  retryCount Int           @default(0)
  queuedAt  DateTime?
  startedAt DateTime?
  lockedAt  DateTime?
  heartbeatAt DateTime?
  timedOutAt DateTime?
  lastError String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum AuditJobStatus {
  QUEUED
  DISPATCHED
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
  CANCELLED
}

model AuditReport {
  id         String   @id @default(cuid())
  auditId    String   @unique
  audit      Audit    @relation(fields: [auditId], references: [id])
  summary    String
  score      Int
  reportJson Json
  markdown   String
  createdAt  DateTime @default(now())
}

model EventLog {
  id        String   @id @default(cuid())
  auditId   String?
  audit     Audit?   @relation(fields: [auditId], references: [id])
  name      String
  props     Json?
  createdAt DateTime @default(now())
}
